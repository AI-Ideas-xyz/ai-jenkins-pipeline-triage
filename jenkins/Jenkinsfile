import groovy.json.JsonOutput

pipeline {
    agent any

    parameters {
        choice(
            name: 'TEST_CATEGORY',
            choices: ['playwright-e2e', 'eks-deploy'],
            description: 'Category of tests to run'
        )
        choice(
            name: 'EKS_SCENARIO',
            choices: ['random', 'CrashLoopBackOff', 'OOMKilled', 'ImagePullBackOff', 'ReadinessProbeFailed'],
            description: 'EKS failure scenario (only used if category is eks-deploy)'
        )
    }

    environment {
        GITHUB_TOKEN = credentials('github-pat-token')
        WORKSPACE_DIR = '/workspace'
        GITHUB_REPO = 'pramodhkumars7/ai-jenkins-pipeline-triage'
    }

    stages {
        stage('Setup') {
            steps {
                script {
                    echo "Starting pipeline for category: ${params.TEST_CATEGORY}"
                    sh "cd ${WORKSPACE_DIR} && ls -la"
                }
            }
        }

        stage('Install Dependencies') {
            when {
                expression { params.TEST_CATEGORY == 'playwright-e2e' }
            }
            steps {
                dir("${WORKSPACE_DIR}") {
                    sh '''
                        npm install
                        npx playwright install chromium
                    '''
                }
            }
        }

        stage('Run Playwright Tests') {
            when {
                expression { params.TEST_CATEGORY == 'playwright-e2e' }
            }
            steps {
                script {
                    dir("${WORKSPACE_DIR}") {
                        def testResult = sh(
                            script: 'npm test 2>&1 | tee test-output.log; exit ${PIPESTATUS[0]}',
                            returnStatus: true
                        )

                        echo "Test exit code: ${testResult}"

                        def failureLog = readFile('test-output.log').trim()

                        def hasFailed = testResult != 0 || failureLog.contains('failed')

                        if (hasFailed) {
                            echo "===== TESTS FAILED ====="
                            echo "Triggering GitHub Actions triage workflow..."

                            // Create JSON payload using JsonOutput for proper escaping
                            def payloadMap = [
                                event_type: 'pipeline-failure',
                                client_payload: [
                                    log: failureLog,
                                    category: 'playwright-e2e',
                                    job: "jenkins-local-${env.JOB_NAME}",
                                    source: 'jenkins-local',
                                    timestamp: new Date().format('yyyy-MM-dd HH:mm:ss')
                                ]
                            ]

                            def payloadJson = JsonOutput.toJson(payloadMap)
                            writeFile file: 'github-dispatch-payload.json', text: payloadJson

                            def result = sh(
                                script: """
                                    curl -s -w "\\nHTTP_CODE:%{http_code}" -X POST \
                                      -H "Accept: application/vnd.github.v3+json" \
                                      -H "Authorization: Bearer ${GITHUB_TOKEN}" \
                                      -H "Content-Type: application/json" \
                                      https://api.github.com/repos/${GITHUB_REPO}/dispatches \
                                      -d @github-dispatch-payload.json
                                """,
                                returnStdout: true
                            ).trim()

                            echo "GitHub API Response: ${result}"

                            if (result.contains('HTTP_CODE:204') || result.contains('HTTP_CODE:200')) {
                                echo "✓ Successfully triggered GitHub Actions triage workflow"
                                echo "View at: https://github.com/${GITHUB_REPO}/actions"
                            } else {
                                echo "⚠ GitHub Actions trigger response: ${result}"
                            }

                            error("Playwright tests failed - GitHub Actions triage triggered")
                        } else {
                            echo "All tests passed!"
                        }
                    }
                }
            }
        }

        stage('Simulate EKS Failure') {
            when {
                expression { params.TEST_CATEGORY == 'eks-deploy' }
            }
            steps {
                script {
                    dir("${WORKSPACE_DIR}") {
                        def failureLog = sh(
                            script: """
                                python3 scripts/gen_eks_log.py ${params.EKS_SCENARIO}
                            """,
                            returnStdout: true
                        ).trim()

                        echo "Generated EKS failure log:"
                        echo failureLog

                        // Create JSON payload using JsonOutput
                        def payloadMap = [
                            event_type: 'pipeline-failure',
                            client_payload: [
                                log: failureLog,
                                category: 'eks-deploy',
                                job: "jenkins-local-${env.JOB_NAME}",
                                source: 'jenkins-local',
                                timestamp: new Date().format('yyyy-MM-dd HH:mm:ss')
                            ]
                        ]

                        def payloadJson = JsonOutput.toJson(payloadMap)
                        writeFile file: 'github-dispatch-payload.json', text: payloadJson

                        def result = sh(
                            script: """
                                curl -s -w "\\nHTTP_CODE:%{http_code}" -X POST \
                                  -H "Accept: application/vnd.github.v3+json" \
                                  -H "Authorization: Bearer ${GITHUB_TOKEN}" \
                                  -H "Content-Type: application/json" \
                                  https://api.github.com/repos/${GITHUB_REPO}/dispatches \
                                  -d @github-dispatch-payload.json
                            """,
                            returnStdout: true
                        ).trim()

                        echo "GitHub API Response: ${result}"

                        if (result.contains('HTTP_CODE:204') || result.contains('HTTP_CODE:200')) {
                            echo "✓ Successfully triggered GitHub Actions triage workflow"
                        }

                        error("EKS deployment failed (simulated)")
                    }
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed'
        }
        failure {
            echo 'Pipeline failed - GitHub Action triage has been triggered'
        }
        success {
            echo 'Pipeline succeeded'
        }
    }
}
